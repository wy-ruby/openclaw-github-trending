# AI 配置项。兼容 OpenAI API 或 Anthropic API 供应商。如果未配置，将使用 OpenClaw 的 AI 配置。
API_KEY=sk-xxxxxxxxxxxxxxxx
BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# 并发配置项（AI 摘要工作线程数，推荐：3-10，默认：5）
MAX_WORKERS=5

# GitHub 配置项（可选，但建议配置以避免速率限制）
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 热门项目时间范围配置项
# Options: daily (当天), weekly (本周), monthly (本月，默认项)
TRENDING_SINCE=weekly

# Email 发送者配置项
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=GitHub Trending

# Email 接收者配置项（可选，如果不配置则发送给发送者自己）
# 提示：如果要发送给其他人，请设置此配置项
EMAIL_TO=recipient@example.com

# SMTP 设置项
EMAIL_USE_TLS=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_TIMEOUT=30

# Feishu 配置项（可选）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# History 配置项
HISTORY_ENABLED=true
STAR_THRESHOLD=100